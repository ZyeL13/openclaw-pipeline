# --- Frontend (Dashboard) ---
dashboard/node_modules/
dashboard/.next/
dashboard/out/
dashboard/build/
dashboard/.vercel/
dashboard/*.log

# --- Python & System Garbage ---
__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.env
.DS_Store
.venv/
venv/
pip-log.txt

# --- OpenClaw Heavy Assets (Ignore folder, not files) ---
# Kita ignore hasil render yang berat agar repo tidak bengkak
**/output/*/scenes/
**/output/**/*.mp4
**/output/**/*.png
**/output/**/*.mp3
**/output/**/*.wav

# --- Specific Heavy Binaries ---
piper/

# --- Keep Data & Configs (PENTING) ---
# Jangan ignore .json secara global agar package.json terdeteksi
# Kita hanya ignore file output/log sementara yang tidak perlu di-dashboard
variations_output.json
*_log.json

konten/client_secrets.json
